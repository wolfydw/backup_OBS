# ============================================================
# exclude.list
# ============================================================
# 说明：
# 1. 本文件只放“默认排除规则”，一般不用修改。
# 2. 如果要添加业务自定义排除规则，请编辑 exclude.user.list。
# 3. 规则由 tar --exclude-from 读取，匹配的是归档内相对路径，不是绝对路径。
# 4. 排除目录时，建议同时写：
#    */dir
#    */dir/*
# ============================================================

# ============================================================
# 默认排除：日志、临时文件、运行时文件
# ============================================================
*.log
*.log.*
*.tmp
*.pid
*.sock
*.lock
*.swp
*.swo
.DS_Store
Thumbs.db

# ============================================================
# 默认排除：本备份工具可能生成的归档和校验文件
# 避免把旧备份再次打进新备份包
# ============================================================
backup_*.tar.gz
backup_*.tar.gz.*
*.sha256
*.gpg

# ============================================================
# 默认排除：通用缓存和临时目录
# ============================================================
*/.cache
*/.cache/*
*/tmp
*/tmp/*
*/temp
*/temp/*

# ============================================================
# 默认排除：Node.js / 前端相关
# ============================================================
*/node_modules
*/node_modules/*
*/.npm/_cacache
*/.npm/_cacache/*
*/.next
*/.next/*
*/.nuxt
*/.nuxt/*

# ============================================================
# 默认排除：Python 相关
# ============================================================
*/__pycache__
*/__pycache__/*
*/.pytest_cache
*/.pytest_cache/*
*/.mypy_cache
*/.mypy_cache/*
*/.tox
*/.tox/*
*/.venv
*/.venv/*
*/venv
*/venv/*
.coverage
.coverage.*
*/coverage
*/coverage/*

# ============================================================
# 默认排除：Java / JVM / 通用编译产物
# ============================================================
*.o
*.class
*/target
*/target/*
*/build
*/build/*
*/dist
*/dist/*
*/.gradle
*/.gradle/*

# ============================================================
# 默认排除：编辑器 / IDE
# ============================================================
*/.idea
*/.idea/*
*/.vscode
*/.vscode/*

# ============================================================
# 默认排除：Terraform / 基础设施缓存
# ============================================================
*/.terraform
*/.terraform/*
*.tfstate
*.tfstate.*
